# Environment files and local secrets
.env
.env.*
backend/.env
frontend/.env
!.env.example
!backend/.env.example
!frontend/.env.example

# Dependencies
backend/vendor/
frontend/node_modules/

# Frontend build output and caches
frontend/dist/
frontend/node_modules/.vite/

# Laravel local/runtime files
backend/public/storage
backend/storage/app/public/
backend/storage/framework/cache/
backend/storage/framework/sessions/
backend/storage/framework/testing/
backend/storage/framework/views/
backend/storage/logs/*.log
backend/bootstrap/cache/*.php

# Local databases and dumps
*.sqlite
*.sqlite-shm
*.sqlite-wal
*.sql

# OS/editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
